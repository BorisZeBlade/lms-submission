{
  "name": "lms-submission-testing",
  "version": "1.0.0",
  "description": "Final exam project for Software Testing and Quality Assurance - Submission in an LMS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:setup": "node scripts/setupDatabase.js",
    "db:reset": "node scripts/resetDatabase.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand",
    "cypress:open": "cypress open",
    "cypress:run": "node scripts/runCypressWithServer.js",
    "load:test": "node scripts/runLoadTestWithServer.js",
    "load:report": "node scripts/generateLoadReport.js",
    "cypress:run:only": "cypress run"
  },
  "keywords": [
    "software-testing",
    "nodejs",
    "express",
    "postgresql",
    "jest",
    "supertest",
    "cypress",
    "artillery",
    "lms"
  ],
  "author": "Roman Nesterenko",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "artillery": "^2.0.22",
    "cross-env": "^7.0.3",
    "cypress": "^13.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/config/db.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}
